# Environment variables for gen_data_finetune
# Copy this file to .env and fill in your actual values

# Main API Key (used by current provider)
API_KEY=your-api-key-here

# Legacy API keys (if LLM_PROVIDER is set to different value)
ANTHROPIC_API_KEY=sk-ant-your-api-key-here
OPENAI_API_KEY=sk-your-openai-key-here
GEMINI_API_KEY=your-gemini-api-key-here

# Optional: Override default settings in config.py
# LLM_PROVIDER=gemini
# MODEL_NAME=gemini-2-flash-preview
# NUM_RECORDS=100
# BATCH_SIZE=10
